{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "back-end",
    "projectType": "application",
    "tags": ["@dnd-mapp/back-end"],
    "sourceRoot": "projects/back-end/src",
    "targets": {
        "build": {
            "executor": "@nx/webpack:webpack",
            "outputs": ["{options.outputPath}"],
            "dependsOn": ["data"],
            "defaultConfiguration": "prod",
            "options": {
                "outputPath": "dist/back-end",
                "webpackConfig": "projects/back-end/webpack.config.ts"
            },
            "configurations": {
                "prod": {},
                "dev": {}
            }
        },
        "serve": {
            "executor": "@nx/js:node",
            "options": {
                "buildTarget": "back-end:build:dev",
                "inspect": false
            }
        },
        "start": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    {
                        "command": "nx build data --watch",
                        "prefix": "[data]:\t\t"
                    },
                    {
                        "command": "nx build shared-components --watch",
                        "prefix": "[shared-components]:\t\t"
                    },
                    {
                        "command": "nx build front-end --watch",
                        "prefix": "[front-end]:\t"
                    },
                    {
                        "command": "nx serve back-end",
                        "prefix": "[back-end]:\t"
                    }
                ],
                "envFile": ".env",
                "color": true
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/back-end"],
            "options": {
                "jestConfig": "projects/back-end/jest.config.ts"
            },
            "defaultConfiguration": "ci",
            "configurations": {
                "dev": {
                    "watchAll": true
                },
                "ci": {
                    "ci": true
                }
            }
        },
        "prisma": {
            "executor": "nx:run-commands",
            "options": {
                "args": ["--schema prisma/schema.prisma"]
            },
            "configurations": {
                "generate-client": {
                    "command": "npx prisma generate client"
                },
                "run-migrations": {
                    "command": "npx prisma migrate dev"
                }
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": ["{options.outputFile}"]
        }
    }
}
