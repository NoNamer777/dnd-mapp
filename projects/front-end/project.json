{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "front-end",
    "projectType": "application",
    "tags": ["@dnd-mapp/front-end"],
    "sourceRoot": "projects/front-end/src",
    "prefix": "dma",
    "targets": {
        "build": {
            "executor": "@angular-builders/custom-webpack:browser",
            "outputs": ["{options.outputPath}"],
            "dependsOn": ["data", "shared-components"],
            "options": {
                "allowedCommonJsDependencies": ["validator", "@paralleldrive/cuid2"],
                "assets": ["projects/front-end/src/favicon.ico", "projects/front-end/src/assets"],
                "baseHref": "/app/",
                "main": "projects/front-end/src/main.ts",
                "customWebpackConfig": {
                    "path": "projects/front-end/webpack.config.ts",
                    "mergeRules": {
                        "resolve": "append"
                    }
                },
                "deleteOutputPath": true,
                "index": "projects/front-end/src/index.html",
                "inlineStyleLanguage": "scss",
                "outputPath": "dist/front-end",
                "polyfills": ["zone.js"],
                "scripts": [],
                "styles": ["projects/front-end/src/styles.scss"],
                "tsConfig": "projects/front-end/tsconfig.app.json"
            },
            "defaultConfiguration": "prod",
            "configurations": {
                "dev": {
                    "buildOptimizer": false,
                    "namedChunks": true,
                    "outputHashing": "none",
                    "optimization": false,
                    "sourceMap": true,
                    "watch": true
                },
                "prod": {
                    "extractLicenses": true,
                    "outputHashing": "all",
                    "progress": false,
                    "optimization": {
                        "scripts": true,
                        "styles": {
                            "inlineCritical": false,
                            "minify": true
                        },
                        "fonts": {
                            "inline": false
                        }
                    },
                    "subresourceIntegrity": true
                }
            }
        },
        "test": {
            "executor": "@angular-devkit/build-angular:karma",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "assets": [
                    "projects/front-end/src/assets",
                    "projects/front-end/src/favicon.ico",
                    {
                        "glob": "*",
                        "input": "projects/shared-components/src/assets",
                        "output": "./"
                    },
                    {
                        "glob": "*",
                        "input": "projects/front-end/.msw",
                        "output": "./"
                    }
                ],
                "codeCoverage": true,
                "codeCoverageExclude": ["**/testing/**", "**/*.module.ts", "**/index.ts", "**/environments/**"],
                "fileReplacements": [
                    {
                        "replace": "projects/front-end/src/assets/config/config.json",
                        "with": "projects/front-end/src/assets/config/config.test.json"
                    }
                ],
                "inlineStyleLanguage": "scss",
                "karmaConfig": "projects/front-end/karma.conf.js",
                "main": "projects/front-end/src/test.ts",
                "polyfills": ["zone.js", "zone.js/testing"],
                "scripts": [],
                "styles": ["projects/front-end/src/styles.scss"],
                "stylePreprocessorOptions": {
                    "includePaths": ["projects/shared-components/src"]
                },
                "tsConfig": "projects/front-end/tsconfig.spec.json",
                "watch": false
            },
            "configurations": {
                "dev": {
                    "progress": true,
                    "sourceMap": true,
                    "watch": true
                },
                "ci": {
                    "progress": false,
                    "sourceMap": false
                }
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}
