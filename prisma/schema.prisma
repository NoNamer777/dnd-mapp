// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
    shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum TokenType {
    Access
    Refresh
}

model User {
    id           String @id
    username     String @unique(map: "unique_user_idx")
    password     String
    emailAddress String @map("email_address")

    roles  UserRole[]
    tokens Token[]
}

model Role {
    id String @id
    name String @unique(map: "unique_role_idx")

    users UserRole[]
}

model UserRole {
    userId String @map("user_id")
    roleId String @map("role_id")

    user User @relation(fields: [userId], references: [id], map: "user_role_fk")
    role Role @relation(fields: [roleId], references: [id], map: "role_user_fk")

    @@id(fields: [userId, roleId])
}

model Session {
    id                  String    @id
    codeChallenge       String?   @map("code_challenge")
    authorizationCode   String?   @map("authorization_code")
    authCodeGeneratedAt DateTime? @map("auth_code_generated_at")

    tokens Token[]
}

model Token {
    jti       String    @id
    subject   String
    sessionId String    @map("session_id")
    type      TokenType
    revoked   Boolean   @default(false)
    notBefore DateTime  @map("not_before")
    issuedAt  DateTime  @map("issued_at")
    expiresAt DateTime  @map("expires_at")

    user    User    @relation(fields: [subject], references: [id], map: "user_token_fk")
    session Session @relation(fields: [sessionId], references: [id], map: "session_token_fk")
}

model Race {
    id   String @id
    name String @unique(map: "unique_race_idx")
}

model Ability {
    id   String @id
    name String @unique(map: "unique_ability_idx")

    skills Skill[]
}

model Skill {
    id        String @id
    name      String @unique(map: "unique_skill_idx")
    abilityId String @map("ability_id")

    ability Ability @relation(fields: [abilityId], references: [id], map: "ability_skill_fk")
}
